{
    "name": "replace-me",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=22 <27",
        "npm": ">=10"
    },
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc -p tsconfig.build.json",
        "start": "node dist/index.js",
        "test": "node --test",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "lint": "eslint .",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "check": "npm run typecheck && npm run lint && npm test && npm run format:check",
        "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
        "clean:modules": "node -e \"fs.rmSync('node_modules', { recursive: true, force: true })\"",
        "clean:lock": "node -e \"fs.rmSync('package-lock.json', { force: true })\"",
        "reinstall": "npm run clean:modules && npm ci",
        "reset:deps": "npm run clean:modules && npm run clean:lock && npm install"
    },
    "devDependencies": {
        "@eslint/js": "latest",
        "@types/node": "latest",
        "eslint": "latest",
        "globals": "17.7.0",
        "prettier": "latest",
        "tsx": "latest",
        "typescript": "latest",
        "typescript-eslint": "latest"
    },
    "allowScripts": {
        "esbuild@0.28.1": true
    }
}
