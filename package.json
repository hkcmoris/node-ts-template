{
    "name": "replace-me",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=22.18 <27",
        "npm": ">=10"
    },
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc -p tsconfig.build.json",
        "start": "node dist/index.js",
        "test": "node --import tsx --test \"test/**/*.test.ts\"",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "lint": "eslint .",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "check": "npm run typecheck && npm run lint && npm test && npm run format:check",
        "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
        "clean:modules": "node -e \"fs.rmSync('node_modules', { recursive: true, force: true })\"",
        "clean:lock": "node -e \"fs.rmSync('package-lock.json', { force: true })\"",
        "reinstall": "npm run clean:modules && npm ci",
        "reset:deps": "npm run clean:modules && npm run clean:lock && npm install"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@types/node": "22.20.1",
        "eslint": "10.6.0",
        "globals": "17.7.0",
        "prettier": "3.9.5",
        "tsx": "4.23.0",
        "typescript": "6.0.3",
        "typescript-eslint": "8.63.0"
    },
    "allowScripts": {
        "esbuild": true
    },
    "dependencies": {
        "dotenv": "17.4.2",
        "pino": "10.3.1"
    }
}
